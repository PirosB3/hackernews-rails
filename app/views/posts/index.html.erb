<% content_for(:title) { "Hacker News" } %>

<%= turbo_stream_from "posts" %>

<table class="w-full" cellpadding="0" cellspacing="0">
  <tbody id="posts">
    <% @posts.each_with_index do |post, index| %>
      <%= render partial: "posts/post", locals: { post: post, rank: ((@page - 1) * 30) + index + 1 } %>
    <% end %>
  </tbody>
</table>

<% if @posts.length == 30 %>
  <div class="ml-10 mt-2 mb-4">
    <%= link_to "More", url_for(page: @page + 1), class: "text-black text-[10pt]" %>
  </div>
<% end %>
