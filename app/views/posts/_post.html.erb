<%= turbo_frame_tag dom_id(post) do %>
  <tr class="align-top">
    <td class="text-right text-[#828282] text-[10pt] pr-1 w-8">
      <% if local_assigns[:rank] %>
        <%= rank %>.
      <% end %>
    </td>
    <td class="w-4 text-center">
      <% if logged_in? && !current_user.voted_on?(post) %>
        <%= button_to votes_path, method: :post, params: { votable_type: "Post", votable_id: post.id }, class: "inline" do %>
          <span class="cursor-pointer text-[#828282] hover:text-[#ff6600] text-[10pt]">▲</span>
        <% end %>
      <% elsif logged_in? && current_user.voted_on?(post) %>
        <span class="text-[#ff6600] text-[10pt]">▲</span>
      <% end %>
    </td>
    <td>
      <div>
        <% if post.url.present? %>
          <a href="<%= post.url %>" class="text-black visited:text-[#828282] no-underline text-[10pt]"><%= post.title %></a>
          <span class="text-[8pt] text-[#828282]">(<%= post.domain %>)</span>
        <% else %>
          <%= link_to post.title, post_path(post), class: "text-black visited:text-[#828282] no-underline text-[10pt]" %>
        <% end %>
      </div>
      <div class="text-[8pt] text-[#828282]">
        <span id="<%= dom_id(post, :points) %>"><%= post.points %> point<%= post.points == 1 ? "" : "s" %></span>

        by <%= link_to post.user.username, user_path(username: post.user.username), class: "text-[#828282] hover:underline" %>
        <%= time_ago_in_words_short(post.created_at) %>
        |
        <% if logged_in? && current_user.voted_on?(post) %>
          <%= button_to "unvote", vote_path(current_user.vote_for(post)), method: :delete, class: "text-[#828282] hover:underline inline bg-transparent border-0 p-0 cursor-pointer text-[8pt]" %>
          |
        <% end %>
        <%= link_to "#{post.comments_count} comment#{'s' if post.comments_count != 1}", post_path(post), class: "text-[#828282] hover:underline" %>
      </div>
    </td>
  </tr>
  <tr class="h-[5px]"></tr>
<% end %>
