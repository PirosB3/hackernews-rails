<% content_for(:title) { @post.title } %>

<%= turbo_stream_from @post %>

<div>
  <table cellpadding="0" cellspacing="0">
    <tr class="align-top">
      <td class="w-4 text-center">
        <% if logged_in? && !current_user.voted_on?(@post) %>
          <%= button_to votes_path, method: :post, params: { votable_type: "Post", votable_id: @post.id }, class: "inline" do %>
            <span class="cursor-pointer text-[#828282] hover:text-[#ff6600] text-[10pt]">▲</span>
          <% end %>
        <% elsif logged_in? && current_user.voted_on?(@post) %>
          <span class="text-[#ff6600] text-[10pt]">▲</span>
        <% end %>
      </td>
      <td>
        <div>
          <% if @post.url.present? %>
            <a href="<%= @post.url %>" class="text-black no-underline text-[10pt]"><%= @post.title %></a>
            <span class="text-[8pt] text-[#828282]">(<%= @post.domain %>)</span>
          <% else %>
            <span class="text-black text-[10pt]"><%= @post.title %></span>
          <% end %>
        </div>
        <div class="text-[8pt] text-[#828282]">
          <span id="<%= dom_id(@post, :points) %>"><%= @post.points %> point<%= @post.points == 1 ? "" : "s" %></span>
          by <%= link_to @post.user.username, user_path(username: @post.user.username), class: "text-[#828282] hover:underline" %>
          <%= time_ago_in_words_short(@post.created_at) %>
          <% if logged_in? && current_user.voted_on?(@post) %>
            | <%= button_to "unvote", vote_path(current_user.vote_for(@post)), method: :delete, class: "text-[#828282] hover:underline inline bg-transparent border-0 p-0 cursor-pointer text-[8pt]" %>
          <% end %>
          <% if logged_in? && @post.user == current_user %>
            | <%= link_to "edit", edit_post_path(@post), class: "text-[#828282] hover:underline" %>
            | <%= button_to "delete", post_path(@post), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-[#828282] hover:underline inline bg-transparent border-0 p-0 cursor-pointer text-[8pt]" %>
          <% end %>
        </div>
      </td>
    </tr>
  </table>

  <% if @post.body.present? %>
    <div class="mt-3 ml-4 text-[10pt] whitespace-pre-wrap"><%= @post.body %></div>
  <% end %>

  <%# Comment Form %>
  <% if logged_in? %>
    <div class="mt-4 ml-4">
      <%= form_with(model: [@post, @comment], url: post_comments_path(@post), class: "text-[10pt]") do |f| %>
        <div class="mb-2">
          <%= f.text_area :body, rows: 6, cols: 60, class: "border border-gray-400 p-1 text-[10pt] font-[Verdana,Geneva,sans-serif]" %>
        </div>
        <%= f.submit "add comment", class: "bg-gray-200 border border-gray-400 px-2 py-0.5 cursor-pointer text-[10pt]" %>
      <% end %>
    </div>
  <% end %>

  <%# Comments %>
  <div class="mt-4" id="<%= dom_id(@post, :comments) %>">
    <% @comments.each do |comment| %>
      <%= render partial: "comments/comment", locals: { comment: comment, depth: 0 } %>
    <% end %>
  </div>
</div>
