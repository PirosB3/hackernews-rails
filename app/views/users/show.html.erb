<% content_for(:title) { @user.username } %>

<div class="text-[10pt]">
  <table cellpadding="2" class="mb-4">
    <tr>
      <td class="text-right text-[#828282]">user:</td>
      <td class="font-bold"><%= @user.username %></td>
    </tr>
    <tr>
      <td class="text-right text-[#828282]">created:</td>
      <td><%= @user.created_at.strftime("%B %d, %Y") %></td>
    </tr>
    <tr>
      <td class="text-right text-[#828282]">karma:</td>
      <td><%= @user.karma %></td>
    </tr>
  </table>

  <h3 class="text-[11pt] font-bold mb-2">Submissions</h3>
  <% if @posts.any? %>
    <table class="w-full mb-4" cellpadding="0" cellspacing="0">
      <% @posts.each do |post| %>
        <tr>
          <td class="py-0.5">
            <% if post.url.present? %>
              <a href="<%= post.url %>" class="text-black visited:text-[#828282] no-underline"><%= post.title %></a>
              <span class="text-[8pt] text-[#828282]">(<%= post.domain %>)</span>
            <% else %>
              <%= link_to post.title, post_path(post), class: "text-black visited:text-[#828282] no-underline" %>
            <% end %>
            <span class="text-[8pt] text-[#828282]">
              — <%= post.points %> points, <%= time_ago_in_words_short(post.created_at) %>
            </span>
          </td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p class="text-[#828282] mb-4">No submissions yet.</p>
  <% end %>

  <h3 class="text-[11pt] font-bold mb-2">Comments</h3>
  <% if @comments.any? %>
    <% @comments.each do |comment| %>
      <div class="mb-3 border-l-2 border-[#ff6600] pl-2">
        <div class="text-[8pt] text-[#828282]">
          on: <%= link_to comment.post.title, post_path(comment.post), class: "text-[#828282] hover:underline" %>
          — <%= time_ago_in_words_short(comment.created_at) %>
        </div>
        <div class="text-[10pt] mt-0.5 whitespace-pre-wrap"><%= comment.body %></div>
      </div>
    <% end %>
  <% else %>
    <p class="text-[#828282]">No comments yet.</p>
  <% end %>
</div>
